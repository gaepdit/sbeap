@using Sbeap.WebApp.Platform.Settings
@{
    var identifier = User.Identity?.Name;

    // Raygun
    var raygunApiKey = AppSettings.RaygunSettings.ApiKey;

    if (!string.IsNullOrEmpty(raygunApiKey))
    {
<script asp-add-content-to-csp>
  !function(a,b,c,d,e,f,g,h){a.RaygunObject=e,a[e]=a[e]||function(){
  (a[e].o=a[e].o||[]).push(arguments)},f=b.createElement(c),g=b.getElementsByTagName(c)[0],
  f.async=1,f.src=d,g.parentNode.insertBefore(f,g),h=a.onerror,a.onerror=function(b,c,d,f,g){
  h&&h(b,c,d,f,g),g||(g=new Error(b)),a[e].q=a[e].q||[],a[e].q.push({
  e:g})}}(window,document,"script","//cdn.raygun.io/raygun4js/raygun.min.js","rg4js");
</script>
<script asp-add-nonce>
    rg4js('apiKey', '@raygunApiKey');
    rg4js('setVersion', '@AppSettings.Version');
    rg4js('enableCrashReporting', true);
    rg4js('withTags', ['@AppSettings.Env']);
    @if (identifier is not null)
    {
        @:rg4js('enableRealUserMonitoring', true);
        @:rg4js('setUser', {isAnonymous: false, identifier: '@identifier'});
    }
</script>
<environment names="Production">
    <script asp-add-content-to-csp>rg4js('enablePulse', true);</script>
</environment>
    }

    // DataDog
    var ddClientToken = AppSettings.DataDogSettings.ClientToken;
    var ddApplicationId = AppSettings.DataDogSettings.ApplicationId;

    if (!string.IsNullOrEmpty(ddClientToken) && !string.IsNullOrEmpty(ddApplicationId))
    {
        <script asp-add-nonce>
            (function (h, o, u, n, d) {
                h = h[d] = h[d] || {
                    q: [], onReady: function (c) {
                        h.q.push(c)
                    }
                }
                d = o.createElement(u);
                d.async = 1;
                d.src = n;
                d.crossOrigin = ''
                n = o.getElementsByTagName(u)[0];
                n.parentNode.insertBefore(d, n)
            })(window, document, 'script', 'https://www.datadoghq-browser-agent.com/us3/v6/datadog-rum.js', 'DD_RUM')
            window.DD_RUM.onReady(function () {
                window.DD_RUM.init({
                    clientToken: '@ddClientToken',
                    applicationId: '@ddApplicationId',
                    site: 'us3.datadoghq.com',
                    service: 'sbeap',
                    env: '@AppSettings.ShortEnv',
                    version: '@AppSettings.SimpleVersion',
                    sessionSampleRate: 100,
                    sessionReplaySampleRate: 20,
                    trackBfcacheViews: true,
                    defaultPrivacyLevel: 'mask-user-input',
                });
            })
        </script>
    }
}
